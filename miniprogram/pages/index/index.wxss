/* pages/index/index.wxss - 重新设计版本 */

/* ============================================
   设计规范应用：
   - 字体：使用 -apple-system, BlinkMacSystemFont
   - 色彩：OKLCH 空间，背景 #0f0f0f (暗色主题)
   - 间距：8px 倍数系统
   - 动效：cubic-bezier(0.16, 1, 0.3, 1)
   ============================================ */

/* --- 登录卡片 --- */
.login-card {
  background: oklch(0.15 0.02 260);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  margin: 24rpx;
  border: 1rpx solid oklch(0.3 0.02 260);
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: oklch(0.98 0.02 80);
  margin-bottom: 48rpx;
  letter-spacing: -0.02em;
}

.form-group {
  margin-bottom: 40rpx;
}

.form-group .label {
  display: block;
  color: oklch(0.7 0.02 80);
  font-size: 26rpx;
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.form-group input,
.form-group .picker {
  width: 100%;
  padding: 28rpx 32rpx;
  border: 2rpx solid oklch(0.35 0.02 260);
  border-radius: 20rpx;
  font-size: 32rpx;
  color: oklch(0.98 0.02 80);
  background: oklch(0.1 0.02 260);
  box-sizing: border-box;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.form-group input:focus,
.form-group .picker:focus {
  border-color: oklch(0.7 0.2 280);
  outline: none;
}

.form-group .picker {
  color: oklch(0.6 0.02 80);
}

/* 登录按钮 */
.btn {
  width: 100%;
  padding: 32rpx;
  border: none;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: oklch(0.1 0.02 260);
  background: oklch(0.85 0.15 80);
  margin-top: 16rpx;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* --- 运势卡片 --- */
.fortune-card {
  background: oklch(0.15 0.02 260);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  margin: 24rpx;
  border: 1rpx solid oklch(0.3 0.02 260);
}

.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid oklch(0.25 0.02 260);
  margin-bottom: 40rpx;
  font-size: 28rpx;
}

.user-bar .greeting {
  color: oklch(0.7 0.02 80);
}

.user-bar .nickname {
  color: oklch(0.85 0.15 80);
  font-weight: 600;
}

.user-bar .switch-btn {
  color: oklch(0.5 0.02 80);
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  background: oklch(0.2 0.02 260);
  border-radius: 12rpx;
  transition: background 0.2s;
}

.user-bar .switch-btn:active {
  background: oklch(0.3 0.02 260);
}

/* 分数圆环 - 核心视觉 */
.score-section {
  text-align: center;
  margin-bottom: 56rpx;
  position: relative;
}

.score-circle {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: conic-gradient(
    oklch(0.7 0.18 280) var(--score-deg),
    oklch(0.25 0.02 260) 0
  );
  margin: 0 auto 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.score-circle::before {
  content: '';
  position: absolute;
  inset: 8rpx;
  border-radius: 50%;
  background: oklch(0.15 0.02 260);
}

.score-inner {
  width: 200rpx;
  height: 200rpx;
  background: transparent;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.score-number {
  font-size: 88rpx;
  font-weight: 800;
  color: oklch(0.98 0.02 80);
  letter-spacing: -0.04em;
}

.score-label {
  color: oklch(0.6 0.02 80);
  font-size: 26rpx;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

/* 运势详情 - 进度条 */
.fortune-details {
  margin-bottom: 40rpx;
}

.fortune-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid oklch(0.2 0.02 260);
}

.fortune-item:last-child {
  border-bottom: none;
}

.fortune-item .label {
  width: 96rpx;
  color: oklch(0.6 0.02 80);
  font-size: 26rpx;
}

.fortune-item .bar {
  flex: 1;
  height: 12rpx;
  background: oklch(0.25 0.02 260);
  border-radius: 6rpx;
  margin: 0 24rpx;
  overflow: hidden;
  position: relative;
}

.fortune-item .bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.fortune-item .value {
  width: 56rpx;
  text-align: right;
  font-weight: 700;
  font-size: 28rpx;
  color: oklch(0.85 0.1 80);
}

/* 幸运信息 - 卡片式 */
.lucky-info {
  display: flex;
  justify-content: space-between;
  padding: 32rpx;
  background: oklch(0.2 0.02 260);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
}

.lucky-item {
  text-align: center;
  flex: 1;
  position: relative;
}

.lucky-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 48rpx;
  background: oklch(0.3 0.02 260);
}

.lucky-item .lucky-label {
  font-size: 22rpx;
  color: oklch(0.5 0.02 80);
  margin-bottom: 12rpx;
  display: block;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.lucky-item .lucky-value {
  font-size: 32rpx;
  font-weight: 700;
  color: oklch(0.9 0.12 60);
}

/* 宜忌 - 极简对比 */
.tips-section {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.tip-box {
  flex: 1;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  text-align: center;
  border: 1rpx solid;
}

.tip-box.good {
  background: oklch(0.18 0.05 150);
  border-color: oklch(0.35 0.08 150);
}

.tip-box.bad {
  background: oklch(0.18 0.05 20);
  border-color: oklch(0.35 0.08 20);
}

.tip-title {
  font-size: 22rpx;
  color: oklch(0.6 0.02 80);
  margin-bottom: 8rpx;
  display: block;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.tip-content {
  font-size: 30rpx;
  color: oklch(0.9 0.02 80);
  font-weight: 600;
}

/* 打卡按钮 */
.checkin-btn {
  width: 100%;
  padding: 36rpx;
  border: none;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: oklch(0.1 0.02 260);
  background: oklch(0.85 0.18 80);
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.checkin-btn:active:not([disabled]) {
  transform: scale(0.97);
}

.checkin-btn.checked {
  background: oklch(0.3 0.02 260);
  color: oklch(0.5 0.02 80);
}

.checkin-btn[disabled] {
  opacity: 0.6;
}

/* --- 日历卡片 --- */
.calendar-card {
  background: oklch(0.15 0.02 260);
  border-radius: 32rpx;
  padding: 40rpx;
  margin: 24rpx;
  border: 1rpx solid oklch(0.3 0.02 260);
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.calendar-title {
  font-size: 30rpx;
  font-weight: 600;
  color: oklch(0.9 0.02 80);
}

.streak-info {
  font-size: 26rpx;
  color: oklch(0.7 0.15 30);
  font-weight: 500;
}

.weekdays {
  display: flex;
  margin-bottom: 16rpx;
}

.weekdays text {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: oklch(0.5 0.02 80);
  font-weight: 500;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.calendar-grid .day {
  width: 14.28%;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: oklch(0.7 0.02 80);
  margin-bottom: 8rpx;
}

.calendar-grid .day.empty {
  color: transparent;
}

.calendar-grid .day.checked {
  background: oklch(0.7 0.18 280);
  color: oklch(0.1 0.02 260);
  border-radius: 50%;
  font-weight: 600;
}

.calendar-grid .day.today {
  border: 2rpx solid oklch(0.7 0.18 280);
  border-radius: 50%;
}

.calendar-grid .day.today.checked {
  border: none;
}

/* --- 加载状态 --- */
.loading {
  text-align: center;
  padding: 80rpx;
  color: oklch(0.5 0.02 80);
}

.skeleton {
  background: linear-gradient(
    90deg,
    oklch(0.2 0.02 260) 0%,
    oklch(0.28 0.02 260) 50%,
    oklch(0.2 0.02 260) 100%
  );
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 12rpx;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
