/* pages/index/index.wxss */

/* 登录卡片 */
.login-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin: 20rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group .label {
  display: block;
  color: #666;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.form-group input,
.form-group .picker {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-group .picker {
  color: #333;
}

/* 运势卡片 */
.fortune-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 20rpx;
}

.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #666;
}

.user-bar .nickname {
  color: #667eea;
  font-weight: 600;
}

.user-bar .switch-btn {
  color: #999;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 分数圆环 */
.score-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.score-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: conic-gradient(#667eea var(--score-deg), #f0f0f0 0);
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-inner {
  width: 200rpx;
  height: 200rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-number {
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.score-label {
  color: #666;
  font-size: 28rpx;
}

/* 运势详情 */
.fortune-details {
  margin-bottom: 32rpx;
}

.fortune-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.fortune-item .label {
  width: 80rpx;
  color: #666;
  font-size: 28rpx;
}

.fortune-item .bar {
  flex: 1;
  height: 16rpx;
  background: #e0e0e0;
  border-radius: 8rpx;
  margin: 0 20rpx;
  overflow: hidden;
}

.fortune-item .bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.fortune-item .value {
  width: 60rpx;
  text-align: right;
  font-weight: 600;
  font-size: 28rpx;
  color: #333;
}

/* 幸运信息 */
.lucky-info {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.lucky-item {
  text-align: center;
}

.lucky-item .lucky-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: block;
}

.lucky-item .lucky-value {
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* 宜忌 */
.tips-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.tip-box {
  flex: 1;
  padding: 28rpx;
  border-radius: 16rpx;
  text-align: center;
}

.tip-box.good {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.tip-box.bad {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

.tip-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.tip-content {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

/* 打卡按钮 */
.checkin-btn {
  width: 100%;
  padding: 32rpx;
  border: none;
  border-radius: 16rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.checkin-btn:after {
  border: none;
}

.checkin-btn.checked {
  background: #e0e0e0;
  color: #999;
}

/* 日历卡片 */
.calendar-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 20rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.streak-info {
  font-size: 28rpx;
  color: #667eea;
}

.weekdays {
  display: flex;
  margin-bottom: 16rpx;
}

.weekdays text {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.calendar-grid .day {
  width: 14.28%;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.calendar-grid .day.checked {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50%;
}

.calendar-grid .day.today {
  border: 4rpx solid #667eea;
  border-radius: 50%;
}

/* 加载动画 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
