<!--pages/profile/profile.wxml-->
<view class="container">
  <view class="profile-card" wx:if="{{userInfo}}">
    <view class="avatar">
      <text class="avatar-text">{{userInfo.nickname[0]}}</text>
    </view>
    <text class="nickname">{{userInfo.nickname}}</text>
    <text class="birthday">生日: {{userInfo.birthday}}</text>
  </view>

  <view class="menu-card" wx:if="{{userInfo}}">
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearData">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清除本地数据</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item logout" bindtap="logout">
      <text class="menu-icon">🚪</text>
      <text class="menu-text">退出登录</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="empty" wx:if="{{!userInfo}}">
    <view class="empty-icon">🔮</view>
    <text class="empty-text">请先登录</text>
    <button class="btn" bindtap="goToIndex" style="margin-top: 40rpx;">去登录</button>
  </view>

  <!-- 云开发环境信息 -->
  <view class="cloud-info" wx:if="{{userInfo}}">
    <text class="cloud-text">数据存储在微信云开发</text>
  </view>
</view>
